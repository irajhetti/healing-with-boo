generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js required models ──

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  phone          String?
  pressurePref   String?   @default("Medium")
  healthNotes    String?
  role           Role      @default(CLIENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  bookings       Booking[]
  discountCodes          DiscountCode[]
  discountUsages         DiscountUsage[]
  consultationResponses  ConsultationResponse[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Business models ──

model Service {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  category    ServiceCategory
  description String?
  duration    Int // minutes
  price       Int // pence (£27 = 2700)
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  bookings Booking[]
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique
  status          BookingStatus @default(CONFIRMED)
  serviceId       String
  userId          String?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  startTime       DateTime
  endTime         DateTime
  price           Int // pence, snapshot at booking time
  discountCodeId  String?
  discountAmount  Int? // pence saved by discount
  stripeSessionId String?       @unique
  stripePaymentId String?
  notes           String?
  cancelledAt     DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  service       Service        @relation(fields: [serviceId], references: [id])
  user          User?          @relation(fields: [userId], references: [id])
  discountUsage DiscountUsage?

  @@index([startTime])
  @@index([userId])
  @@index([status])
}

enum Role {
  CLIENT
  ADMIN
}

enum ServiceCategory {
  MASSAGE
  HEALING
  COMBINED
  SIGNATURE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ── Admin: Availability ──

model BusinessHours {
  id        String   @id @default(cuid())
  dayOfWeek Int      @unique // 0=Sunday .. 6=Saturday
  open      String? // "14:00" — null means closed
  close     String? // "20:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockedDate {
  id             String   @id @default(cuid())
  date           DateTime @unique // stored as midnight UTC
  reason         String?
  openOverride   String? // if set, day has custom hours instead of being blocked
  closeOverride  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Discount Codes ──

enum DiscountType {
  PERCENTAGE
  FIXED
}

model DiscountCode {
  id           String       @id @default(cuid())
  code         String       @unique // stored uppercase
  discountType DiscountType
  amount       Int // percentage (20 = 20%) or pence (500 = £5)
  maxUses      Int? // null = unlimited
  usedCount    Int          @default(0)
  expiresAt    DateTime?
  active       Boolean      @default(true)
  userId       String? // null = general, set = personal code for this member
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user   User?           @relation(fields: [userId], references: [id])
  usages DiscountUsage[]

  @@index([userId])
}

model DiscountUsage {
  id             String   @id @default(cuid())
  discountCodeId String
  bookingId      String   @unique // one discount per booking
  userId         String? // null = guest
  originalPrice  Int // pence
  discountAmount Int // pence deducted
  createdAt      DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])
  booking      Booking      @relation(fields: [bookingId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([discountCodeId])
  @@index([userId])
}

// ── Consultation Form ──

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  DROPDOWN
  YES_NO
}

model ConsultationQuestion {
  id        String       @id @default(cuid())
  label     String
  type      QuestionType
  options   String? // JSON array for DROPDOWN: '["Option A","Option B"]'
  required  Boolean      @default(false)
  sortOrder Int          @default(0)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  responses ConsultationResponse[]
}

model ConsultationResponse {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  question ConsultationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}
